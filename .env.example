# OpenAI API Key (required for career analysis)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Cashfree Payments (required for payment)
# Get these from Cashfree Dashboard → Developers → API Keys
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
# "sandbox" for testing, "production" for live payments
CASHFREE_MODE=sandbox

# Must match CASHFREE_MODE — used by the frontend SDK
NEXT_PUBLIC_CASHFREE_MODE=sandbox

# App URL (used for payment return redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gmail SMTP for report delivery
# Use an App Password, NOT your regular Gmail password
# Steps: Google Account → Security → 2-Step Verification → App Passwords → Generate
SMTP_EMAIL=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password
